  "failed_retry_batch": 20,
  "failed_push_ttl_seconds": 1800,
  "qb_clients": [
    {
      "name": "qb-1",
      "enabled": true,
      "qb_url": "http://127.0.0.1:8080",
      "qb_username": "admin",
      "qb_password": "YOUR_QB_PASSWORD",
      "qb_category": "",
      "qb_savepath": "",
      "qb_paused": false
    }
  ]
}
